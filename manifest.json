{
  "manifest_version": 3,
  "name": "JAGRES AI ASSISTANT - Twitter Edition v1",
  "version": "1.0.0",
  "description": "Jagres AI Assistant for Twitter - Natural human-like replies with Indonesian/Japanese/English support",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://api.groq.com/*",
    "https://api.duckduckgo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "styles.css",
        "icons/16.png",
        "icons/48.png",
        "icons/128.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}